<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard – Il Vicino Torino</title>

    <link rel="stylesheet" href="styles.css">
</head>

<body>

    <!-- LOGIN SCREEN (verrà nascosto dall’URL segreto) -->
    <div id="login-screen" class="login-screen">
        <h2>Accesso Riservato</h2>
        <p>Inserisci la password per accedere</p>
      <input type="password" id="passwordInput" placeholder="Password">
        <button id="loginBtn">Accedi</button>
    </div>

    <!-- DASHBOARD -->
    <div id="dashboard" class="dashboard">

        <!-- SIDEBAR -->
        <ul class="sidebar">
            <li data-section="consigli" class="active">Consigli</li>
            <li data-section="eventi">Eventi</li>
            <li data-section="ristoranti">Ristoranti</li>
            <li data-section="negozi">Negozi</li>
            <li data-section="altro">Altro</li>
        </ul>

        <!-- MAIN VIEW -->
        <div id="view" class="view">
            <h2>Benvenuto nella Dashboard</h2>
            <p>Seleziona una sezione dal menu.</p>
        </div>

        <!-- LOADER -->
        <div id="loader" class="loader hidden">Caricamento...</div>

        <!-- TOAST -->
        <div id="toast" class="toast"></div>

        <!-- TEMA SCURO -->
        <button id="themeToggle" class="theme-toggle">🌓</button>

    </div>

    <!-- SCRIPT CORRETTO -->
    <script src="admin-dashboard-7Qp93A4Lk.js"></script>

</body>
</html>
